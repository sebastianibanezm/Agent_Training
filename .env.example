# Required — set any password you want to protect your app
DEMO_PASSWORD=

# Required — random string (32+ chars) used to sign session cookies
# Generate with: openssl rand -base64 32
# Changing this will log out any active sessions.
SESSION_SECRET=

# Required — from supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required — from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Optional — unlocks live web search for agents. From app.tavily.com
TAVILY_API_KEY=
